# Bootstrap local (npm run setup:env → gera apps/api/.env e apps/web/.env).
# Produção com front na Vercel e API no Render: configure as variáveis nos painéis (Vercel / Render),
# não dependa deste ficheiro — veja apps/web/.env.example e apps/api/.env.example.

PORT=3000
CORS_ORIGIN=http://localhost:3016,http://127.0.0.1:3016
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sitecompras?schema=public
UPLOADS_DIR=./uploads

# Dev local opcional:
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
# API_BACKEND_URL=http://127.0.0.1:3000
