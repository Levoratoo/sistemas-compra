{
  "name": "api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "start": "node scripts/start.mjs",
    "start:server-only": "node dist/server.js",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev --skip-generate",
    "db:push": "npm run db:migrate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:users": "tsx prisma/seed-users-only.ts",
    "db:seed:suppliers": "tsx prisma/seed-suppliers-demo.ts",
    "db:backfill-supplier-cnd": "tsx src/scripts/backfill-supplier-cnd.ts",
    "db:backfill-supplier-cnd-metadata": "tsx src/scripts/backfill-supplier-cnd-metadata.ts",
    "test": "node --import tsx/esm --test src/utils/*.test.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.296",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "prisma": "^6.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
