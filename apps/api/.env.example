PORT=3000
# Opcional: alguns hosts expõem só HTTP_PORT; a API aceita como fallback.
# HTTP_PORT=3000
#
# --- Obrigatório no Render (produção): segredo para assinar JWT (login). Mínimo 32 caracteres. ---
# Gerar localmente: openssl rand -base64 32
# No painel: Environment → Add → Key JWT_SECRET, Value (colar o segredo).
# JWT_SECRET=coloque_aqui_um_segredo_com_pelo_menos_32_caracteres
#
# --- Produção: API no Render + front na Vercel ---
# CORS: URL(s) do front (vírgula). A API também aceita automaticamente qualquer https://*.vercel.app (previews/branches).
# CORS_ORIGIN=https://seu-projeto.vercel.app
#
# PostgreSQL no Render: Web Service → Environment → "Add from Database" no Postgres,
# ou cole a Internal Database URL (com ?sslmode=require).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sitecompras?schema=public
# Produção no Render com disco persistente: UPLOADS_DIR=/var/data/uploads
# Desenvolvimento local: pode manter ./uploads
UPLOADS_DIR=./uploads

# PDF "Mapa de Implantação": tamanho máximo do texto extraído (caracteres). O conteúdo é lido do documento inteiro; listas são detectadas por padrão, não por página fixa.
IMPLEMENTATION_MAP_PDF_MAX_CHARS=120000

# OCR (PDF renderizado e imagens em /ocr/image): idiomas Tesseract. Mesma variável para os dois fluxos.
# PDF_OCR_LANG=por+eng

# --- EmailJS (e-mail ao supervisor registar item faltante → notifica o aprovador) ---
# Web3Forms é só para o formulário /contact no Next; isto é envio pelo servidor (Render).
# Ative com true e preencha IDs/chaves em https://www.emailjs.com/
# Envio pelo servidor: EMAILJS_PRIVATE_KEY (Account → API Keys) recomendada.
# EMAILJS_ENABLED=true
# EMAILJS_SERVICE_ID=service_xxx
# EMAILJS_TEMPLATE_ID=template_xxx
# EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
# EMAILJS_PRIVATE_KEY=xxxxxxxxxxxxxxxx
# Destinatário: OWNER_APPROVAL_EMAIL OU (se vazio) primeiro utilizador ativo com papel APPROVER na base.
# OWNER_APPROVAL_EMAIL=aprovador@empresa.com.br
# URL pública do front (link "abrir pedido" no e-mail). Produção: Vercel, ex. https://seu-projeto.vercel.app
# PUBLIC_APP_URL=https://seu-projeto.vercel.app
