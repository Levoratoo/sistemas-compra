generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  PLANNED
  ACTIVE
  ON_HOLD
  CLOSED
  CANCELLED
}

enum ImplementationStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum DocumentType {
  NOTICE
  TERMS_OF_REFERENCE
  IMPLEMENTATION_MAP
  COST_SPREADSHEET
  CONTROL_SPREADSHEET
  PURCHASE_ORDER_PDF
  SUPPLIER_QUOTE_PDF
  OTHER_ATTACHMENT
}

enum DocumentProcessingStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum DocumentReviewStatus {
  PENDING_REVIEW
  REVIEWED
  CONFLICT
  REJECTED
}

enum ExtractedFieldReviewStatus {
  PENDING_REVIEW
  CONFIRMED
  CORRECTED
  REJECTED
  CONFLICT
}

enum ExtractedTargetType {
  PROJECT
  PROJECT_ROLE
  BUDGET_ITEM
}

enum DataOriginType {
  MANUAL
  DOCUMENT_EXTRACTED
}

enum ItemCategory {
  UNIFORM
  EPI
  EQUIPMENT
  CONSUMABLE
  OTHER
}

enum PurchaseStatus {
  TO_START
  QUOTING
  UNDER_REVIEW
  APPROVAL_PENDING
  APPROVED
  PAYMENT_PENDING
  COMPLETED
  CANCELLED
}

enum DeliveryStatus {
  NOT_SCHEDULED
  SCHEDULED
  PARTIALLY_DELIVERED
  DELIVERED
  DELAYED
  CANCELLED
}

enum ReplenishmentTriggerType {
  FROM_DELIVERY
  FROM_PROJECT_START
  FROM_LAST_REPLENISHMENT
  MANUAL
}

enum IntervalUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum TaskCategory {
  DOCUMENTATION
  TEAM
  UNIFORMS
  EPI
  EQUIPMENT
  TRAINING
  TIME_TRACKING
  COMPLIANCE
  GENERAL
}

enum FolderSurfaceStyle {
  SOLID
  GRADIENT
  RADIAL
}

enum MissingItemUrgency {
  HIGH
  MEDIUM
  LOW
}

enum OwnerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  ADMIN
  USER
  APPROVER
  SUPERVISOR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole  @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  releasedProjects UserProjectRelease[]

  @@index([role])
  @@index([isActive])
}

model Project {
  id                       String               @id @default(cuid())
  code                     String               @unique
  name                     String
  organizationName         String
  procurementProcessNumber String?
  bidNumber                String?
  contractNumber           String?
  city                     String?
  state                    String?
  objectSummary            String?
  projectStatus            ProjectStatus        @default(DRAFT)
  implementationStatus     ImplementationStatus @default(NOT_STARTED)
  plannedSignatureDate     DateTime?
  plannedStartDate         DateTime?
  actualStartDate          DateTime?
  contractDurationMonths   Int                  @default(12)
  monthlyContractValue     Decimal?
  selectedQuoteSlotNumber  Int?
  notes                    String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  documents             ProjectDocument[]
  documentFolders       ProjectDocumentFolder[]
  roles                 ProjectRole[]
  budgetItems           BudgetItem[]
  quotes                ProjectQuote[]
  quotePurchases        ProjectQuotePurchase[]
  purchaseOrders        PurchaseOrder[]
  implementationTasks   ImplementationTask[]
  missingItemReports    MissingItemReport[]
  releasedToUsers       UserProjectRelease[]

  @@unique([organizationName, procurementProcessNumber])
  @@unique([organizationName, contractNumber])
  @@index([organizationName])
  @@index([bidNumber])
  @@index([projectStatus])
  @@index([implementationStatus])
  @@index([plannedStartDate])
}

model UserProjectRelease {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model ProjectDocumentFolder {
  id        String   @id @default(cuid())
  projectId String
  parentId  String?
  name      String
  sortOrder Int      @default(0)
  /// Cor do ícone/borda (#RRGGBB)
  colorHex  String   @default("#14b8a6")
  /// Segunda cor do degradê / radial (#RRGGBB)
  colorHex2 String   @default("#0ea5e9")
  /// Emoji opcional como “favicon” da pasta
  iconEmoji String?
  /// Aparência do cartão: sólido, degradê linear ou degradê radial
  surfaceStyle FolderSurfaceStyle @default(GRADIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  parent    ProjectDocumentFolder?    @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children  ProjectDocumentFolder[]   @relation("FolderHierarchy")
  documents ProjectDocument[]

  @@index([projectId])
  @@index([projectId, parentId])
}

model ProjectDocument {
  id               String                   @id @default(cuid())
  projectId        String
  folderId         String?
  purchaseOrderId  String?
  /// Vínculo opcional: cópia na documentação do projeto de um anexo CND global do fornecedor.
  supplierCndAttachmentId String?
  documentType     DocumentType
  originalFileName String
  storagePath      String                   @unique
  mimeType         String?
  fileSizeBytes    Int?
  checksum         String?
  documentDate     DateTime?
  searchText       String?
  previewJson      Json?
  processingStatus DocumentProcessingStatus @default(PENDING)
  reviewStatus     DocumentReviewStatus     @default(PENDING_REVIEW)
  processingError  String?
  notes            String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  folder            ProjectDocumentFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  supplierCndAttachment SupplierCndAttachment? @relation(fields: [supplierCndAttachmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  purchaseOrder     PurchaseOrder?          @relation("PurchaseOrderDocuments", fields: [purchaseOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  generatedForPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderGeneratedDocument")
  latestImportedForQuotes    ProjectQuote[]   @relation("ProjectQuoteLatestImportedDocument")
  extractedFields   ExtractedField[]
  sourceRoles              ProjectRole[]         @relation("RoleSourceDocument")
  sourceBudgetItems        BudgetItem[]          @relation("BudgetItemSourceDocument")
  sourceImplementationTasks ImplementationTask[] @relation("TaskSourceDocument")

  @@index([supplierCndAttachmentId])
  @@index([projectId])
  @@index([projectId, folderId])
  @@index([projectId, documentType])
  @@index([projectId, originalFileName])
  @@index([purchaseOrderId])
  @@index([processingStatus])
  @@index([reviewStatus])
  @@index([checksum])
}

model ExtractedField {
  id                String                     @id @default(cuid())
  projectDocumentId String
  targetType        ExtractedTargetType
  recordGroupKey    String?
  fieldKey          String
  proposedValue     String
  confirmedValue    String?
  sourcePage        Int?
  sourceSheetName   String?
  sourceCellRef     String?
  sourceExcerpt     String?
  confidenceScore   Float?
  reviewStatus      ExtractedFieldReviewStatus @default(PENDING_REVIEW)
  reviewNote        String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  projectDocument ProjectDocument @relation(fields: [projectDocumentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([projectDocumentId])
  @@index([targetType])
  @@index([reviewStatus])
  @@index([recordGroupKey])
  @@index([fieldKey])
  @@index([projectDocumentId, targetType, recordGroupKey])
}

model ProjectRole {
  id                   String         @id @default(cuid())
  projectId            String
  roleName             String
  cboCode              String?
  workRegime           String?
  workloadLabel        String?
  allocationSector     String?
  plannedPositions     Int?
  employeesPerPosition Int?
  plannedHeadcount     Int
  sourceType           DataOriginType @default(MANUAL)
  sourceDocumentId     String?
  sourceSheetName      String?
  sourceCellRef        String?
  sourcePage           Int?
  sourceExcerpt        String?
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sourceDocument ProjectDocument? @relation("RoleSourceDocument", fields: [sourceDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([projectId])
  @@index([projectId, roleName])
  @@index([sourceDocumentId])
}

model BudgetItem {
  id               String         @id @default(cuid())
  projectId        String
  itemCategory     ItemCategory
  subcategory      String?
  name             String
  description      String?
  specification    String?
  unit             String?
  sizeLabel        String?
  requiresCa       Boolean?
  roleReference    String?
  allocationSector String?
  plannedQuantity  Decimal?
  bidUnitValue     Decimal?
  /** Valor máximo permitido pela rubrica do edital (teto de compra por item). */
  rubricMaxValue   Decimal?
  /** Valor efetivamente gasto / comprado (controle operacional). */
  purchasedValue   Decimal?
  hasBidReference  Boolean        @default(true)
  /** Trecho do edital só para leitura (ex.: cláusulas 8.7.x); sem previsão de compra/valores. */
  contextOnly      Boolean        @default(false)
  supplierQuoteExtraItem Boolean  @default(false)
  sourceType       DataOriginType @default(MANUAL)
  sourceDocumentId String?
  sourceSheetName  String?
  sourceCellRef    String?
  sourcePage       Int?
  sourceExcerpt    String?
  notes            String?

  /** --- Fase 2: controle operacional (planilha "Projetos - Controles") --- */
  priority                      String?
  peopleCount                   Int?
  /** Status Compras (rótulos da planilha: orçamento, entrega, etc.) */
  operationalPurchaseStatus     String?
  /** Prazo edital para entrega (dias), quando aplicável */
  editalDeliveryDeadlineDays    Int?
  /** Prazo de reposição previsto no edital (dias) */
  replenishmentPeriodDaysEdital Int?
  approvedSupplierName          String?
  glpiTicketNumber              String?
  opPaymentSentAt               DateTime?
  opExpectedDeliveryAt          DateTime?
  opDeliveredAt                 DateTime?
  operationalStagesStatus       String?
  nextReplenishmentExpectedAt   DateTime?
  replenishmentStateLabel       String?
  competenceLabel               String?
  administrativeFeePercent      Decimal?
  /** Valor unitário real (mercado / compra), distinto da rubrica do edital */
  actualUnitValue               Decimal?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sourceDocument     ProjectDocument?    @relation("BudgetItemSourceDocument", fields: [sourceDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  purchaseOrderItems PurchaseOrderItem[]
  quoteItems         ProjectQuoteItem[]
  quotePurchaseItems ProjectQuotePurchaseItem[]
  replenishmentRule  ReplenishmentRule?

  @@index([projectId])
  @@index([projectId, name])
  @@index([projectId, itemCategory])
  @@index([itemCategory])
  @@index([hasBidReference])
  @@index([sourceDocumentId])
}

model ImplementationTask {
  id               String         @id @default(cuid())
  projectId        String
  title            String
  category         TaskCategory
  description      String?
  status           TaskStatus     @default(NOT_STARTED)
  dueDate          DateTime?
  sourceDocumentId String?
  sourcePage       Int?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sourceDocument ProjectDocument? @relation("TaskSourceDocument", fields: [sourceDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([projectId])
  @@index([projectId, category])
  @@index([status])
  @@index([sourceDocumentId])
}

model Supplier {
  id             String   @id @default(cuid())
  legalName      String
  tradeName      String?
  documentNumber String?  @unique
  contactName    String?
  address        String?
  phone          String?
  email          String?
  cnd            String?
  cndIssuedAt    DateTime?
  cndValidUntil  DateTime?
  cndControlCode String?
  cndSourceFileName String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  projectQuotes   ProjectQuote[]
  cndAttachments SupplierCndAttachment[]

  @@index([legalName])
}

/// Arquivo CND canônico por fornecedor (um por upload); replicado em todos os projetos.
model SupplierCndAttachment {
  id                String   @id @default(cuid())
  supplierId        String
  originalFileName  String
  masterStoragePath String   @unique
  mimeType          String?
  fileSizeBytes     Int?
  createdAt         DateTime @default(now())

  supplier          Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  projectDocuments  ProjectDocument[]

  @@index([supplierId])
}

model ProjectQuote {
  id                     String   @id @default(cuid())
  projectId              String
  projectQuotePurchaseId String?
  slotNumber             Int
  supplierId             String?
  latestImportedDocumentId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  project              Project          @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  projectQuotePurchase ProjectQuotePurchase? @relation(fields: [projectQuotePurchaseId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  supplier             Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  latestImportedDocument ProjectDocument? @relation("ProjectQuoteLatestImportedDocument", fields: [latestImportedDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items                ProjectQuoteItem[]

  @@unique([projectQuotePurchaseId, slotNumber])
  @@index([projectId])
  @@index([projectQuotePurchaseId])
  @@index([supplierId])
  @@index([latestImportedDocumentId])
}

model ProjectQuotePurchase {
  id        String   @id @default(cuid())
  projectId  String
  title     String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project        Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  items          ProjectQuotePurchaseItem[]
  quotes         ProjectQuote[]
  purchaseOrders PurchaseOrder[]          @relation("PurchaseOrderSourceQuotePurchase")

  @@index([projectId])
  @@index([projectId, createdAt])
}

model ProjectQuotePurchaseItem {
  id                     String   @id @default(cuid())
  projectQuotePurchaseId String
  budgetItemId           String
  quantity               Decimal?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  projectQuotePurchase ProjectQuotePurchase @relation(fields: [projectQuotePurchaseId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  budgetItem           BudgetItem           @relation(fields: [budgetItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([projectQuotePurchaseId, budgetItemId])
  @@index([budgetItemId])
}

model ProjectQuoteItem {
  id             String   @id @default(cuid())
  projectQuoteId String
  budgetItemId   String
  unitPrice      Decimal?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectQuote ProjectQuote @relation(fields: [projectQuoteId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  budgetItem   BudgetItem   @relation(fields: [budgetItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([projectQuoteId, budgetItemId])
  @@index([budgetItemId])
}

model PurchaseOrder {
  id                String         @id @default(cuid())
  projectId         String
  sourceQuotePurchaseId String?
  supplierId        String?
  purchaseStatus    PurchaseStatus @default(TO_START)
  purchaseDate      DateTime?
  internalReference String?
  glpiNumber        String?
  deliveryAddress   String?
  freightType       String?
  paymentTerms      String?
  responsibleName   String?
  responsiblePhone  String?
  expectedDeliveryDate DateTime?
  generatedDocumentId String?      @unique
  paymentSentAt     DateTime?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sourceQuotePurchase ProjectQuotePurchase? @relation("PurchaseOrderSourceQuotePurchase", fields: [sourceQuotePurchaseId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  supplier          Supplier?           @relation(fields: [supplierId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  generatedDocument ProjectDocument?    @relation("PurchaseOrderGeneratedDocument", fields: [generatedDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  documents         ProjectDocument[]   @relation("PurchaseOrderDocuments")
  items             PurchaseOrderItem[]

  @@unique([sourceQuotePurchaseId, supplierId, glpiNumber])
  @@index([projectId])
  @@index([sourceQuotePurchaseId])
  @@index([projectId, glpiNumber])
  @@index([supplierId])
  @@index([purchaseStatus])
  @@index([purchaseDate])
  @@index([paymentSentAt])
  @@index([internalReference])
}

model PurchaseOrderItem {
  id                   String         @id @default(cuid())
  purchaseOrderId      String
  budgetItemId         String
  quantityPurchased    Decimal
  realUnitValue        Decimal
  expectedDeliveryDate DateTime?
  deliveredAt          DateTime?
  deliveryStatus       DeliveryStatus @default(NOT_SCHEDULED)
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  purchaseOrder       PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  budgetItem          BudgetItem           @relation(fields: [budgetItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  replenishmentEvents ReplenishmentEvent[]

  @@index([purchaseOrderId])
  @@index([budgetItemId])
  @@index([deliveryStatus])
  @@index([expectedDeliveryDate])
  @@index([deliveredAt])
}

model ReplenishmentRule {
  id            String                   @id @default(cuid())
  budgetItemId  String                   @unique
  triggerType   ReplenishmentTriggerType
  intervalUnit  IntervalUnit
  intervalValue Int
  warningDays   Int                      @default(30)
  baseDate      DateTime?
  isEnabled     Boolean                  @default(true)
  notes         String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  budgetItem BudgetItem           @relation(fields: [budgetItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  events     ReplenishmentEvent[]

  @@index([isEnabled])
}

model ReplenishmentEvent {
  id                  String    @id @default(cuid())
  replenishmentRuleId String
  purchaseOrderItemId String?
  baseDateUsed        DateTime
  plannedDate         DateTime
  completedDate       DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  replenishmentRule ReplenishmentRule  @relation(fields: [replenishmentRuleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  purchaseOrderItem PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([replenishmentRuleId, plannedDate])
  @@index([plannedDate])
  @@index([completedDate])
  @@index([purchaseOrderItemId])
}

model MissingItemReport {
  id                    String               @id @default(cuid())
  projectId             String
  requesterName         String
  requestDate           DateTime
  itemToAcquire         String
  estimatedQuantity     String
  necessityReason       String
  urgencyLevel          MissingItemUrgency
  ownerApprovalStatus   OwnerApprovalStatus  @default(PENDING)
  ownerApprovedAt       DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  project      Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attachments MissingItemReportAttachment[]

  @@index([projectId])
  @@index([projectId, requestDate])
}

model MissingItemReportAttachment {
  id                  String   @id @default(cuid())
  missingItemReportId String
  originalFileName    String
  storagePath         String   @unique
  mimeType            String?
  fileSizeBytes       Int?
  createdAt           DateTime @default(now())

  report MissingItemReport @relation(fields: [missingItemReportId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([missingItemReportId])
}
