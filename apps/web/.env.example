# Local: API Express (apps/api) na porta padrão.
NEXT_PUBLIC_API_URL=http://localhost:3000/api
#
# Produção (GitHub Pages, Render static, etc.): URL pública da API com /api no fim, ex.:
# NEXT_PUBLIC_API_URL=https://sua-api.onrender.com/api
# Tem de estar definida no momento do `npm run build` (variáveis NEXT_PUBLIC_* são embutidas no bundle).
# Na API, CORS_ORIGIN deve incluir a origem exata do frontend (ex.: https://usuario.github.io).
